# 백엔드 환경 변수 예시 — 실제 값은 .env 에 작성하고 커밋하지 마세요.

# 허용할 프론트엔드 오리진 (쉼표로 구분)
BACKEND_CORS_ORIGINS=http://localhost:5173

# PostgreSQL 연결 문자열 (DB 사용 시)
# DATABASE_URL=postgresql+psycopg://rubberduck:changeme@localhost:5432/rubberduck

# GitHub Copilot SDK 토큰 (비밀) — GitHub Models(OpenAI 호환) 사용
# GitHub PAT(models:read 권한). 설정되면 러버덕/파싱/인사이트가 LLM 경로로 동작.
# COPILOT_SDK_TOKEN=
# (선택) 기본값: https://models.github.ai/inference
# COPILOT_SDK_BASE_URL=
# (선택) 기본값: openai/gpt-4o-mini
# COPILOT_SDK_MODEL=

# 대안: Azure OpenAI (둘 다 설정되면 Azure OpenAI 우선)
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com
# AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
# AZURE_OPENAI_API_VERSION=2024-10-21
